---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Further Reading" activeSection="further-reading">

  <section style="background: #0f1419; padding: 3rem 1rem;">
    <div style="max-width: 48rem; margin: 0 auto; text-align: center;">
      <h1 style="font-family: 'Cormorant Garamond', serif; color: #faf5ee; font-size: 2rem; font-weight: 600;">Further Reading</h1>
      <p style="color: #a8a29e; font-size: 0.95rem; margin-top: 0.5rem;">Key sources informing this project</p>
    </div>
  </section>

  <section style="max-width: 48rem; margin: 0 auto; padding: 3rem 1rem;">
    <div style="font-family: 'Lora', serif; color: #44403c; font-size: 0.95rem; line-height: 1.8;">

      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 600; color: #1c1917; margin-bottom: 1rem; border-bottom: 1px solid #e7e5e4; padding-bottom: 0.5rem;">Primary Sources</h2>

      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">
        McGrath, Alister E. <em>The Territories of Human Reason: Science and Theology in an Age of Multiple Rationalities.</em> Oxford: Oxford University Press, 2019.
        <span style="font-family: sans-serif; font-size: 0.75rem; color: #a8a29e;"> — <a href={`${base}presentation#opening`} style="color: #c9a84c; text-decoration: none;">cited in Opening</a></span>
      </p>
      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">
        McGrath, Alister E. <em>Science and Religion: A New Introduction.</em> 3rd ed. Chichester: Wiley-Blackwell, 2020.
        <span style="font-family: sans-serif; font-size: 0.75rem; color: #a8a29e;"> — <a href={`${base}presentation#opening`} style="color: #c9a84c; text-decoration: none;">cited in Opening</a>, <a href={`${base}presentation#act-ii`} style="color: #c9a84c; text-decoration: none;">Act II</a></span>
      </p>
      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">
        Nguyen, Hoang Hai. <em>The Emptiness of Everything: Contemplating Modern Sciences through Buddhist Principles.</em> 2nd ed. Hanoi: VNU Press, 2025.
        <span style="font-family: sans-serif; font-size: 0.75rem; color: #a8a29e;"> — <a href={`${base}presentation#act-i`} style="color: #c9a84c; text-decoration: none;">cited in Acts I</a>–<a href={`${base}presentation#closing`} style="color: #c9a84c; text-decoration: none;">Closing</a></span>
      </p>

      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 600; color: #1c1917; margin: 2rem 0 1rem; border-bottom: 1px solid #e7e5e4; padding-bottom: 0.5rem;">Science and Theology</h2>

      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">Barbour, Ian G. <em>Religion in an Age of Science.</em> San Francisco: Harper &amp; Row, 1990. <span style="font-family: sans-serif; font-size: 0.75rem; color: #a8a29e;"> — <a href={`${base}presentation#act-ii`} style="color: #c9a84c; text-decoration: none;">cited in Act II</a></span></p>
      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">Bhaskar, Roy. <em>A Realist Theory of Science.</em> London: Routledge, 2008 [1975].</p>
      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">Harrison, Peter. <em>The Territories of Science and Religion.</em> Chicago: University of Chicago Press, 2015. <span style="font-family: sans-serif; font-size: 0.75rem; color: #a8a29e;"> — <a href={`${base}presentation#act-i`} style="color: #c9a84c; text-decoration: none;">cited in Act I</a></span></p>
      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">Jaki, Stanley L. <em>The Road of Science and the Ways to God.</em> Chicago: University of Chicago Press, 1978. <span style="font-family: sans-serif; font-size: 0.75rem; color: #a8a29e;"> — <a href={`${base}presentation#act-i`} style="color: #c9a84c; text-decoration: none;">cited in Act I</a></span></p>
      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">Polkinghorne, John. <em>Science and Theology: An Introduction.</em> Minneapolis: Fortress Press, 1998.</p>
      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">Torrance, Thomas F. <em>Theological Science.</em> London: Oxford University Press, 1969. <span style="font-family: sans-serif; font-size: 0.75rem; color: #a8a29e;"> — <a href={`${base}presentation#act-i`} style="color: #c9a84c; text-decoration: none;">cited in Act I</a>, <a href={`${base}presentation#act-iv`} style="color: #c9a84c; text-decoration: none;">Act IV</a></span></p>

      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 600; color: #1c1917; margin: 2rem 0 1rem; border-bottom: 1px solid #e7e5e4; padding-bottom: 0.5rem;">Philosophy and Ethics</h2>

      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">Feser, Edward. <em>Aristotle's Revenge: The Metaphysical Foundations of Physical and Biological Science.</em> Neunkirchen-Seelscheid: Editiones Scholasticae, 2019. <span style="font-family: sans-serif; font-size: 0.75rem; color: #a8a29e;"> — <a href={`${base}presentation#act-iv`} style="color: #c9a84c; text-decoration: none;">cited in Act IV</a></span></p>
      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">MacIntyre, Alasdair. <em>After Virtue.</em> 3rd ed. Notre Dame: University of Notre Dame Press, 2007. <span style="font-family: sans-serif; font-size: 0.75rem; color: #a8a29e;"> — <a href={`${base}presentation#act-ii`} style="color: #c9a84c; text-decoration: none;">cited in Act II</a></span></p>
      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">Midgley, Mary. <em>The Myths We Live By.</em> London: Routledge, 2003. <span style="font-family: sans-serif; font-size: 0.75rem; color: #a8a29e;"> — <a href={`${base}presentation#act-iv`} style="color: #c9a84c; text-decoration: none;">cited in Act IV</a></span></p>
      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">Otto, Rudolf. <em>Das Heilige.</em> Breslau: Trewendt &amp; Granier, 1917. English: <em>The Idea of the Holy.</em> <span style="font-family: sans-serif; font-size: 0.75rem; color: #a8a29e;"> — <a href={`${base}presentation#act-v`} style="color: #c9a84c; text-decoration: none;">cited in Act V</a></span></p>

      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 600; color: #1c1917; margin: 2rem 0 1rem; border-bottom: 1px solid #e7e5e4; padding-bottom: 0.5rem;">Science, Cosmology, and Biology</h2>

      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">Barrow, John D., and Frank J. Tipler. <em>The Anthropic Cosmological Principle.</em> Oxford: Oxford University Press, 1986. <span style="font-family: sans-serif; font-size: 0.75rem; color: #a8a29e;"> — <a href={`${base}presentation#act-i`} style="color: #c9a84c; text-decoration: none;">cited in Act I</a></span></p>
      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">Rose, Steven. <em>Lifelines: Biology Beyond Determinism.</em> Oxford: Oxford University Press, 1997. <span style="font-family: sans-serif; font-size: 0.75rem; color: #a8a29e;"> — <a href={`${base}presentation#opening`} style="color: #c9a84c; text-decoration: none;">cited in Opening</a>, <a href={`${base}presentation#act-i`} style="color: #c9a84c; text-decoration: none;">Act I</a></span></p>

      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 600; color: #1c1917; margin: 2rem 0 1rem; border-bottom: 1px solid #e7e5e4; padding-bottom: 0.5rem;">Buddhist Philosophy and Science</h2>

      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">Wallace, B. Alan, ed. <em>Buddhism and Science: Breaking New Ground.</em> New York: Columbia University Press, 2003.</p>

      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 600; color: #1c1917; margin: 2rem 0 1rem; border-bottom: 1px solid #e7e5e4; padding-bottom: 0.5rem;">Buddhist–Christian Dialogue</h2>

      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">Cobb, John B., Jr., and Christopher Ives, eds. <em>The Emptying God: A Buddhist-Jewish-Christian Conversation.</em> Maryknoll, NY: Orbis Books, 1990.</p>
      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">Makransky, John. <em>Awakening through Love: Unveiling Your Deepest Goodness.</em> Boston: Wisdom Publications, 2007.</p>
      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">Schmidt-Leukel, Perry. <em>Buddhism and Christianity in Dialogue.</em> London: SCM Press, 2005.</p>
      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">Yong, Amos. <em>Pneumatology and the Christian-Buddhist Dialogue: Does the Spirit Blow through the Middle Way?</em> Leiden: Brill, 2012.</p>

      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 600; color: #1c1917; margin: 2rem 0 1rem; border-bottom: 1px solid #e7e5e4; padding-bottom: 0.5rem;">Human Nature and Transhumanism</h2>

      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">Hefner, Philip. <em>The Human Factor: Evolution, Culture, Religion.</em> Minneapolis: Fortress Press, 1993. <span style="font-family: sans-serif; font-size: 0.75rem; color: #a8a29e;"> — <a href={`${base}presentation#act-iii`} style="color: #c9a84c; text-decoration: none;">cited in Act III</a></span></p>
      <p style="margin-bottom: 0.75rem; padding-left: 2rem; text-indent: -2rem;">Peters, Ted. "Imago Dei, DNA, and the Transhuman Way." <em>Theology and Science</em> 16, no. 3 (2018): 353–362. <span style="font-family: sans-serif; font-size: 0.75rem; color: #a8a29e;"> — <a href={`${base}presentation#act-iii`} style="color: #c9a84c; text-decoration: none;">cited in Act III</a></span></p>

    </div>
  </section>

</BaseLayout>
