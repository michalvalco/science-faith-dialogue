---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScholarCard from '../components/ScholarCard.astro';
import { persons } from '../data/presentation';
import { scholarTraditions } from '../data/types';

const grouped = scholarTraditions.map(t => ({
  ...t,
  persons: persons.filter(p => p.tradition === t.key),
})).filter(g => g.persons.length > 0);

const total = persons.length;
---

<BaseLayout title="Scholars" activeSection="scholars">

  <section style="background: #0f1419; padding: 3rem 1rem;">
    <div style="max-width: 48rem; margin: 0 auto; text-align: center;">
      <h1 style="font-family: 'Cormorant Garamond', serif; color: #faf5ee; font-size: 2rem; font-weight: 600;">Scholars</h1>
      <p style="color: #a8a29e; font-size: 0.95rem; margin-top: 0.5rem;">
        {total} thinkers — theologians, philosophers, and scientists — whose work shapes the dialogue between science, faith, and reason
      </p>
    </div>
  </section>

  <!-- Category quick-jump nav -->
  <nav aria-label="Scholar categories" style="max-width: 56rem; margin: 0 auto; padding: 1.5rem 1rem 0;">
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center;">
      {grouped.map(g => (
        <a
          href={`#scholars-${g.key.toLowerCase()}`}
          style={`
            display: inline-flex; align-items: center; gap: 0.35rem;
            padding: 0.4rem 0.85rem; border-radius: 9999px;
            border: 1px solid ${g.color}40; background: ${g.color}08;
            font-family: sans-serif; font-size: 0.75rem; color: ${g.color};
            text-decoration: none; transition: all 0.2s;
          `}
        >
          <span aria-hidden="true">{g.icon}</span>
          {g.label}
          <span style="font-size: 0.65rem; opacity: 0.7;">({g.persons.length})</span>
        </a>
      ))}
    </div>
  </nav>

  <!-- Grouped sections -->
  {grouped.map(g => (
    <section id={`scholars-${g.key.toLowerCase()}`} style="max-width: 56rem; margin: 0 auto; padding: 2.5rem 1rem 0.5rem;">
      <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
        <span style={`display: inline-block; width: 4px; height: 1.75rem; border-radius: 2px; background: ${g.color};`}></span>
        <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 600; color: #1c1917;">
          {g.label}
        </h2>
        <span style="font-family: sans-serif; font-size: 0.7rem; color: #a8a29e; margin-left: 0.25rem;">
          {g.persons.length} scholars
        </span>
      </div>
      <div style="display: grid; grid-template-columns: 1fr; gap: 1rem;">
        {g.persons.map((person) => (
          <ScholarCard person={person} />
        ))}
      </div>
    </section>
  ))}

  <!-- Bottom padding -->
  <div style="padding-bottom: 3rem;"></div>

</BaseLayout>
