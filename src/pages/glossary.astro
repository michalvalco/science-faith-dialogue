---
import BaseLayout from '../layouts/BaseLayout.astro';
import GlossaryCard from '../components/GlossaryCard.astro';
import { keyTerms, nguyenTerms } from '../data/presentation';
import { traditions } from '../data/types';

const grouped = traditions.map(t => ({
  ...t,
  terms: keyTerms.filter(term => term.tradition === t.key),
})).filter(g => g.terms.length > 0);

const totalGeneral = keyTerms.length;
const totalNguyen = nguyenTerms.length;
---

<BaseLayout title="Glossary" activeSection="glossary">

  <section style="background: #0f1419; padding: 3rem 1rem;">
    <div style="max-width: 48rem; margin: 0 auto; text-align: center;">
      <h1 style="font-family: 'Cormorant Garamond', serif; color: #faf5ee; font-size: 2rem; font-weight: 600;">Key Terms</h1>
      <p style="color: #a8a29e; font-size: 0.95rem; margin-top: 0.5rem;">
        {totalGeneral} general terms across Christian theology, Buddhist philosophy, philosophy of science, scientific concepts, and shared traditions — plus {totalNguyen} specialist terms from Nguyen Hoang Hai
      </p>
    </div>
  </section>

  <!-- Category quick-jump nav -->
  <nav aria-label="Glossary categories" style="max-width: 56rem; margin: 0 auto; padding: 1.5rem 1rem 0;">
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center;">
      {grouped.map(g => (
        <a
          href={`#cat-${g.key.toLowerCase()}`}
          style={`
            display: inline-flex; align-items: center; gap: 0.35rem;
            padding: 0.4rem 0.85rem; border-radius: 9999px;
            border: 1px solid ${g.color}40; background: ${g.color}08;
            font-family: sans-serif; font-size: 0.75rem; color: ${g.color};
            text-decoration: none; transition: all 0.2s;
          `}
        >
          <span aria-hidden="true">{g.icon}</span>
          {g.label}
          <span style="font-size: 0.65rem; opacity: 0.7;">({g.terms.length})</span>
        </a>
      ))}
      <a
        href="#cat-nguyen"
        style="
          display: inline-flex; align-items: center; gap: 0.35rem;
          padding: 0.4rem 0.85rem; border-radius: 9999px;
          border: 1px solid #3d8b8b40; background: #3d8b8b08;
          font-family: sans-serif; font-size: 0.75rem; color: #3d8b8b;
          text-decoration: none; transition: all 0.2s;
        "
      >
        <span aria-hidden="true">📘</span>
        Nguyen Hoang Hai
        <span style="font-size: 0.65rem; opacity: 0.7;">({totalNguyen})</span>
      </a>
    </div>
  </nav>

  <!-- General Glossary — grouped by tradition -->
  {grouped.map(g => (
    <section id={`cat-${g.key.toLowerCase()}`} style="max-width: 56rem; margin: 0 auto; padding: 2.5rem 1rem 0.5rem;">
      <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
        <span style={`display: inline-block; width: 4px; height: 1.75rem; border-radius: 2px; background: ${g.color};`}></span>
        <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 600; color: #1c1917;">
          {g.label}
        </h2>
        <span style="font-family: sans-serif; font-size: 0.7rem; color: #a8a29e; margin-left: 0.25rem;">
          {g.terms.length} terms
        </span>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
        {g.terms.map((term) => (
          <GlossaryCard term={term} showTradition={true} />
        ))}
      </div>
    </section>
  ))}

  <!-- Divider -->
  <div style="max-width: 56rem; margin: 0 auto; padding: 2rem 1rem 0;">
    <hr style="border: none; border-top: 2px solid #3d8b8b; opacity: 0.3;" />
  </div>

  <!-- Nguyen Hoang Hai Section -->
  <section id="cat-nguyen" style="max-width: 56rem; margin: 0 auto; padding: 1.5rem 1rem 3rem;">
    <div style="margin-bottom: 1.5rem;">
      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 600; color: #1c1917; margin-bottom: 0.25rem;">
        Nguyen Hoang Hai — <em>The Emptiness of Everything</em> (2025)
      </h2>
      <p style="font-size: 0.85rem; color: #78716c; margin-bottom: 0.75rem;">
        Terms extracted from Nguyen Hoang Hai, <em>The Emptiness of Everything: Contemplating Modern Sciences through Buddhist Principles</em>, 2nd ed. (Hanoi: VNU Press, 2025). These reflect Nguyen's distinctive usage and the specific Buddhist–scientific vocabulary that structures his argument.
      </p>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap; font-size: 0.7rem; font-family: sans-serif; text-transform: uppercase; letter-spacing: 0.1em; color: #a8a29e;">
        <span><span style="display: inline-block; width: 10px; height: 10px; border-radius: 2px; background: #3d8b8b; margin-right: 4px; vertical-align: middle;"></span> Buddhist</span>
        <span><span style="display: inline-block; width: 10px; height: 10px; border-radius: 2px; background: #78716c; margin-right: 4px; vertical-align: middle;"></span> Scientific / Philosophical</span>
      </div>
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
      {nguyenTerms.map((term) => (
        <GlossaryCard term={term} showRefBadge={true} />
      ))}
    </div>
  </section>

</BaseLayout>
