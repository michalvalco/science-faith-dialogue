---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Stránka nenájdená">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <p class="text-8xl mb-6 opacity-30">☸</p>
    <h1 class="font-display text-4xl font-semibold text-ink-950 mb-4">404</h1>
    <p class="text-ink-500 text-lg mb-8 max-w-md mx-auto">
      Táto stránka nebola nájdená. Možno hľadáte niektorý z modulov alebo hlavnú stránku kurzu.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href={base}
         class="px-6 py-3 bg-sacred-500 text-cosmos-950 font-sans font-semibold rounded-lg hover:bg-sacred-400 transition-colors">
        Úvodná stránka
      </a>
      <a href={`${base}sylabus`}
         class="px-6 py-3 border border-sandstone-300 text-ink-600 font-sans rounded-lg hover:bg-sandstone-100 transition-colors">
        Sylabus kurzu
      </a>
    </div>
  </div>
</BaseLayout>
