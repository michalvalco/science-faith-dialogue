---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Page Not Found">
  <div style="max-width: 36rem; margin: 0 auto; padding: 5rem 1rem; text-align: center;">
    <p style="font-size: 5rem; opacity: 0.25; margin-bottom: 1.5rem;">✝ ☸</p>
    <h1 style="font-family: 'Cormorant Garamond', serif; font-size: 2.5rem; font-weight: 600; color: #1c1917; margin-bottom: 1rem;">404</h1>
    <p style="color: #78716c; font-size: 1.05rem; margin-bottom: 2rem; line-height: 1.6;">
      This page could not be found. Perhaps you were looking for the presentation or the glossary?
    </p>
    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem;">
      <a href={base}
         style="padding: 0.75rem 1.5rem; background: #c9a84c; color: #0f1419; font-family: sans-serif; font-weight: 600; border-radius: 0.5rem; text-decoration: none; font-size: 0.9rem;">
        Home
      </a>
      <a href={`${base}presentation`}
         style="padding: 0.75rem 1.5rem; border: 1px solid #e7e5e4; color: #57534e; font-family: sans-serif; border-radius: 0.5rem; text-decoration: none; font-size: 0.9rem;">
        Read the Presentation
      </a>
      <a href={`${base}glossary`}
         style="padding: 0.75rem 1.5rem; border: 1px solid #e7e5e4; color: #57534e; font-family: sans-serif; border-radius: 0.5rem; text-decoration: none; font-size: 0.9rem;">
        Glossary
      </a>
    </div>
  </div>
</BaseLayout>
