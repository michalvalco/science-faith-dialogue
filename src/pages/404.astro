---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Page Not Found">
  <div style="max-width: 36rem; margin: 0 auto; padding: 5rem 1rem; text-align: center;">
    <p style="font-size: 5rem; opacity: 0.25; margin-bottom: 1.5rem;">✝ ☸</p>
    <h1 style="font-family: 'Cormorant Garamond', serif; font-size: 2.5rem; font-weight: 600; color: #1c1917; margin-bottom: 1rem;">404</h1>
    <p style="color: #78716c; font-size: 1.05rem; margin-bottom: 2rem; line-height: 1.6;">
      This page could not be found. Perhaps you were looking for the presentation or the glossary?
    </p>
    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem;">
      <a href={base} class="hero-btn hero-btn--primary">Home</a>
      <a href={`${base}presentation`} class="hero-btn hero-btn--outline">Read the Presentation</a>
      <a href={`${base}glossary`} class="hero-btn hero-btn--outline">Glossary</a>
    </div>
  </div>
</BaseLayout>
