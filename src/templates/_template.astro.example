---
/**
 * MODULE PAGE TEMPLATE — DN II Dejiny náboženstiev
 * =================================================
 *
 * Copy this file to `src/pages/moduly/[tradition].astro` (renaming .example → .astro)
 * and fill in the placeholders marked with TODO. The file structure follows the
 * nine core components (A–I) plus seven UX enhancement layers (J–P) defined in
 * MODULE_TEMPLATE_SPEC.md.
 *
 * CORE COMPONENTS:
 *   A) Hero section
 *   B) Naratívna esej (inline prose — stays in this file)
 *   C) Identifikačná karta (TraditionCard)
 *   D) Kľúčové pojmy (KeyTerms)
 *   E) Kľúčové osobnosti (PersonCard)
 *   F) Úryvky zo svätých textov (SacredTextExcerpts)
 *   G) Študijné otázky (StudyQuestions)
 *   H) Podnety na reflexiu (ReflectionPrompts)
 *   I) Sidebar (right aside — quick facts, related traditions, reading list)
 *
 * UX ENHANCEMENT LAYERS:
 *   J) TermTooltip — inline term definitions on hover/tap (in essay)
 *   K) QuickCheck — formative self-check cards (between essay sections)
 *   L) ConceptMap — tradition-specific concept relationship diagram
 *   M) VideoEmbed — click-to-load video embeds (in essay)
 *   N) [Tradition]Timeline — interactive timeline with European parallels (sidebar)
 *   O) Essay images — <figure> with <img> + <figcaption> (in essay)
 *   P) Print button — "Tlačiť štúdijné materiály" (in TOC sidebar)
 *
 * Before using this template:
 *   1. Create `src/data/[tradition].ts` with all structured data
 *      (see src/data/hinduizmus.ts for the COMPLETE reference example)
 *   2. Create tradition-specific components:
 *      - `src/components/[Tradition]Timeline.tsx` (see HinduTimeline.tsx)
 *      - `src/components/[Tradition]ConceptMap.tsx` (see ConceptMap.tsx for the Hindu example)
 *   3. Ensure the tradition is registered in `src/data/traditions.ts`
 *   4. Create `public/images/[tradition]/` directory for images
 *   5. Write the essay content (Component B)
 *
 * Data types are defined in `src/data/types.ts`.
 * See MODULE_TEMPLATE_SPEC.md for full technical specifications.
 */

// -- Standard component imports (all modules use these) --
import BaseLayout from '../../layouts/BaseLayout.astro';
import TraditionCard from '../../components/TraditionCard';
import KeyTerms from '../../components/KeyTerms';
import PersonCard from '../../components/PersonCard';
import StudyQuestions from '../../components/StudyQuestions';
import ComparisonTable from '../../components/ComparisonTable';
import ImageLightbox from '../../components/ImageLightbox';
import SacredTextExcerpts from '../../components/SacredTextExcerpts.astro';
import ReflectionPrompts from '../../components/ReflectionPrompts.astro';

// -- UX enhancement imports (all modules use these) --
import VideoEmbed from '../../components/VideoEmbed.astro';
import TermTooltip from '../../components/TermTooltip';
import QuickCheck from '../../components/QuickCheck';

// -- Tradition-specific imports (create new per module) --
// TODO: Create and import your tradition-specific components:
// import [Tradition]Timeline from '../../components/[Tradition]Timeline';
// import [Tradition]ConceptMap from '../../components/[Tradition]ConceptMap';
// import [Tradition]Map from '../../components/[Tradition]Map';
// import [Tradition]Pronunciation from '../../components/[Tradition]Pronunciation';

// -- Data imports --
import { traditions } from '../../data/traditions';
import { getAdjacentTraditions } from '../../data/traditions';
// TODO: Replace with your tradition's data file
import {
  traditionData,
  keyTerms, persons, studyQuestions, reflectionPrompts, sacredTexts,
  sections, relatedTraditions, quickFacts, recommendedReading,
  quickChecks,
  // TODO: Add tradition-specific data exports (e.g., vedantaComparison for Hinduism)
} from '../../data/budhizmus'; // TODO: ← change this import path

const base = import.meta.env.BASE_URL;
// TODO: Replace slug with your tradition's slug from traditions.ts
const { prev, next } = getAdjacentTraditions('budhizmus'); // TODO: ← change slug
---

{/* TODO: Set per-module print header (shown in @page running header when printing) */}
<style is:global>
  :root { --print-header: "Dejiny náboženstiev II — Budhizmus"; } {/* TODO: ← change tradition name */}
</style>

{/* TODO: Update title and activeSection to match your tradition */}
<BaseLayout title="Budhizmus" activeSection="budhizmus">

  {/* ================================================================
      A) HERO SECTION
      - Dark bg with subtle symbol watermark
      - Breadcrumb → symbol + title + original script → intro blurb
      TODO: Replace symbol, title, original script, intro text, module #,
            and gradient accent color (sacred-900, terra-900, jade-900, cosmos-900)
      ================================================================ */}
  <section class="relative bg-cosmos-950 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-sacred-900/20 via-cosmos-950 to-cosmos-950"></div>
    {/* TODO: Replace ☸ with the tradition's symbol */}
    <div class="absolute inset-0 opacity-[0.03] text-sacred-400 text-[12rem] font-normal select-none pointer-events-none" aria-hidden="true">
      <div class="absolute top-4 left-[15%]">☸</div>
      <div class="absolute bottom-4 right-[10%]">☸</div>
    </div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
      <div class="breadcrumb mb-6">
        <a href={base}>Úvod</a>
        <span class="separator">›</span>
        <a href={`${base}#tradicie`}>Tradície</a>
        <span class="separator">›</span>
        {/* TODO: Update module number */}
        <span class="text-sandstone-300">Modul X</span>
      </div>
      <div class="flex items-center gap-5 mb-6">
        {/* TODO: Update symbol and title */}
        <span class="text-6xl text-sandstone-100" aria-hidden="true">☸</span>
        <div>
          <h1 class="font-display text-4xl sm:text-5xl font-semibold text-sandstone-50">Názov tradície</h1>
          {/* TODO: Original script + transliteration */}
          <p class="text-sacred-400 font-sans text-sm mt-1">Original script · Transliteration</p>
        </div>
      </div>
      {/* TODO: 2-3 sentence evocative introduction (not a definition) */}
      <p class="text-sandstone-300/80 text-lg max-w-2xl leading-relaxed">
        Evokujúci úvodný text — prečo by sa študent mal o túto tradíciu zaujímať?
      </p>
    </div>
  </section>

  {/* ================================================================
      MOBILE/TABLET SECTION NAV
      Driven by `sections` array from data file. No changes needed.
      ================================================================ */}
  <nav class="lg:hidden sticky top-16 z-40 bg-sandstone-50/95 backdrop-blur-sm border-b border-sandstone-200 print:hidden">
    <div class="px-4 overflow-x-auto">
      <div class="flex gap-1 py-2 min-w-max">
        {sections.map((item) => (
          <a href={`#${item.id}`}
             class="px-3 py-1.5 rounded-md text-sm font-sans text-ink-500 hover:text-cosmos-700 hover:bg-cosmos-50 transition-colors whitespace-nowrap">
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </nav>

  {/* ================================================================
      THREE-COLUMN MODULE LAYOUT
      ================================================================ */}
  <div class="module-layout pt-16 pb-12">

    {/* ──────────────────────────────────────────────────────────────
        LEFT SIDEBAR: Table of Contents (desktop only, lg+)
        Includes: section nav, quick facts, print button
        ────────────────────────────────────────────────────────────── */}
    <aside class="module-toc print:hidden">
      <nav aria-label="Obsah modulu">
        <p class="px-3 mb-3 font-sans text-[0.6875rem] uppercase tracking-wider text-ink-400 font-semibold">Obsah</p>
        {sections.map((item) => (
          <a href={`#${item.id}`}>{item.label}</a>
        ))}
        <div class="mt-6 pt-4 border-t border-sandstone-200">
          <p class="px-3 mb-2 font-sans text-[0.6875rem] uppercase tracking-wider text-ink-400 font-semibold">Rýchle fakty</p>
          <div class="px-3 space-y-2 text-xs font-sans text-ink-500">
            {quickFacts.map((f) => (
              <div><span class="text-ink-400">{f.label}:</span> {f.value}</div>
            ))}
          </div>
        </div>
        {/* P) PRINT BUTTON — "Tlačiť štúdijné materiály"
            Uses id + addEventListener (CSP-safe), NOT inline onclick */}
        <div class="mt-6 pt-4 border-t border-sandstone-200 px-3">
          <button
            type="button"
            id="print-btn"
            class="print-keep w-full flex items-center justify-center gap-2 px-3 py-2 text-xs font-sans font-medium text-ink-500 bg-sandstone-100 hover:bg-sandstone-200 rounded-lg transition-colors"
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true" focusable="false">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
            </svg>
            Tlačiť štúdijné materiály
          </button>
        </div>
      </nav>
    </aside>

    {/* ──────────────────────────────────────────────────────────────
        CENTER: Main content
        ────────────────────────────────────────────────────────────── */}
    <div class="module-content max-w-none">

      {/* ==============================================================
          B) NARATÍVNA ESEJ
          Write 8-12 sections with <h3> headings.
          Use <aside class="margin-note"> for theological reflections.
          Target: 4,000-6,000 words.

          UX LAYERS TO WEAVE INTO THE ESSAY:
          J) TermTooltip — on first occurrence of each major term
          K) QuickCheck — after major section breaks (3-4 total)
          M) VideoEmbed — at contextually relevant points (1-2 total)
          O) Essay images — at visually relevant points (2-5 total)

          See hinduizmus.astro for the complete reference implementation.
          ============================================================== */}
      <section id="esej" class="mb-16 scroll-mt-32 animate-section">
        {/* TODO: Replace with tradition-specific essay title */}
        <h2 class="font-display text-3xl font-semibold text-ink-950 mb-6">Názov eseje</h2>
        <div class="prose">

          {/* TODO: Write essay sections. Pattern:

          <!-- I. Hook / Provocation -->
          <h3 id="esej-uvod">1. Úvodná sekcia</h3>
          <p>Essay text with <TermTooltip client:load term="TermName" terms={keyTerms} label="display text" />...</p>

          <!-- O) Essay image example -->
          <figure class="essay-figure my-6">
            <img
              src="/images/[tradition]/filename.jpg"
              alt="Descriptive alt text in Slovak"
              class="w-full max-w-md mx-auto rounded-lg"
              loading="lazy"
              decoding="async"
            />
            <figcaption class="text-ink-500 text-xs mt-2 font-sans text-center">
              Caption text.
              <span class="block text-ink-400 text-[0.625rem] mt-0.5">Source · license</span>
            </figcaption>
          </figure>

          <aside class="margin-note">
            <strong>Teologická reflexia:</strong> Side comment comparing with Christianity...
          </aside>

          <!-- M) VideoEmbed example -->
          <VideoEmbed
            url="https://www.youtube.com/watch?v=VIDEO_ID"
            title="Video title"
            source="Channel / Year"
            language="sk"
            description="Brief description of why this video is relevant here."
          />

          <!-- K) QuickCheck after section break -->
          <QuickCheck client:load item={quickChecks[0]} />

          <h3 id="esej-section2">2. Next Section</h3>
          ...etc...
          */}

          <h3>I. Placeholder section</h3>
          <p>
            Essay content will go here. This placeholder should be replaced with
            the actual essay text.
          </p>

        </div>
      </section>

      {/* ==============================================================
          L) CONCEPT RELATIONSHIP DIAGRAM
          TODO: Create [Tradition]ConceptMap.tsx and uncomment below.
          Place between essay and identification card.
          ============================================================== */}
      {/* <section id="diagram" class="mb-16 scroll-mt-32 animate-section">
        <h2 class="font-display text-3xl font-semibold text-ink-950 mb-6">Konceptuálna mapa</h2>
        <ImageLightbox client:visible alt="Konceptuálna mapa tradície">
          <[Tradition]ConceptMap />
        </ImageLightbox>
      </section> */}

      {/* ==============================================================
          C) IDENTIFIKAČNÁ KARTA
          TODO: Update accentColor to match the tradition
          Options: "sacred" | "cosmos" | "terra" | "jade"
          ============================================================== */}
      <section id="karta" class="mb-16 scroll-mt-32 animate-section">
        <h2 class="font-display text-3xl font-semibold text-ink-950 mb-6">Identifikačná karta</h2>
        <TraditionCard client:load tradition={traditionData} accentColor="sacred" />
      </section>

      {/* ==============================================================
          D) KĽÚČOVÉ POJMY
          TODO: Update subtitle text for the tradition
          ============================================================== */}
      <section id="pojmy" class="mb-16 scroll-mt-32 animate-section">
        <h2 class="font-display text-3xl font-semibold text-ink-950 mb-2">Kľúčové pojmy</h2>
        {/* TODO: Update tradition name and language in subtitle */}
        <p class="text-ink-500 mb-6">Terminológia tradície v pôvodnom jazyku s vysvetlením</p>
        <KeyTerms client:load terms={keyTerms} tradition="NázovTradície" />
      </section>

      {/* ==============================================================
          E) KĽÚČOVÉ OSOBNOSTI (5-8 PersonCards)
          Driven entirely by `persons` array from data file.
          ============================================================== */}
      <section id="osobnosti" class="mb-16 scroll-mt-32 animate-section">
        <h2 class="font-display text-3xl font-semibold text-ink-950 mb-6">Kľúčové osobnosti</h2>
        <div class="space-y-6">
          {persons.map((person) => (
            <PersonCard client:load person={person} />
          ))}
        </div>
      </section>

      {/* ==============================================================
          F) ÚRYVKY ZO SVÄTÝCH TEXTOV (2-4 excerpts)
          ============================================================== */}
      <SacredTextExcerpts texts={sacredTexts} />

      {/* ==============================================================
          G) ŠTUDIJNÉ OTÁZKY (8-12 questions)
          ============================================================== */}
      <section id="otazky" class="mb-16 scroll-mt-32 animate-section">
        <h2 class="font-display text-3xl font-semibold text-ink-950 mb-2">Študijné otázky</h2>
        <p class="text-ink-500 mb-6">Kliknutím na otázku zobrazíte nápovedu</p>
        <StudyQuestions client:load questions={studyQuestions} />
      </section>

      {/* ==============================================================
          H) PODNETY NA REFLEXIU (3-5 prompts)
          ============================================================== */}
      <ReflectionPrompts prompts={reflectionPrompts} />

      {/* ==============================================================
          NAVIGATION — prev/next module links
          Automatic from getAdjacentTraditions(). No changes needed.
          ============================================================== */}
      <nav class="border-t border-sandstone-200 pt-8 flex justify-between items-center" aria-label="Navigácia medzi modulmi">
        {prev && (
          <a href={`${base}moduly/${prev.slug}`} class="group flex items-center gap-2 text-ink-400 font-sans text-sm hover:text-cosmos-600 transition-colors">
            <span class="group-hover:-translate-x-0.5 transition-transform">&larr;</span>
            <span>{prev.symbol} {prev.label}</span>
          </a>
        )}
        <div></div>
        {next && (
          <a href={`${base}moduly/${next.slug}`} class="group flex items-center gap-2 text-ink-400 font-sans text-sm hover:text-cosmos-600 transition-colors">
            <span>{next.label} {next.symbol}</span>
            <span class="group-hover:translate-x-0.5 transition-transform">&rarr;</span>
          </a>
        )}
      </nav>

    </div>

    {/* ──────────────────────────────────────────────────────────────
        RIGHT SIDEBAR (desktop xl+)
        I) Sidebar cards + N) Timeline
        TODO: Add tradition-specific sidebar content
        ────────────────────────────────────────────────────────────── */}
    <aside class="module-aside print:hidden">

      {/* N) INTERACTIVE TIMELINE with cross-civilizational parallels
          TODO: Create [Tradition]Timeline.tsx and uncomment below.
          See HinduTimeline.tsx for reference (ERA_COLORS, EVENTS, parallel fields).
      <div class="aside-card">
        <p class="aside-card-title">Časová os</p>
        <[Tradition]Timeline client:load />
      </div>
      */}

      {/* TODO: Optional geographic map — see HinduDiasporaMap.tsx for pattern
      <div class="aside-card">
        <p class="aside-card-title">Rozšírenie tradície</p>
        <figure>
          <ImageLightbox client:visible alt="Mapa rozšírenia tradície">
            <[Tradition]Map />
          </ImageLightbox>
          <figcaption>Popis mapy. <span class="text-ink-400 text-[0.625rem]">Kliknutím zväčšíte.</span></figcaption>
        </figure>
      </div>
      */}

      {/* Related traditions — driven by data */}
      <div class="aside-card">
        <p class="aside-card-title">Súvisiace tradície</p>
        <div class="space-y-2">
          {relatedTraditions.map((t) => (
            <a href={`${base}moduly/${t.slug}`} class="flex items-center gap-2 text-ink-600 hover:text-cosmos-700 transition-colors">
              <span class="text-lg" aria-hidden="true">{t.symbol}</span>
              <div>
                <div class="font-semibold text-[0.8125rem]">{t.name}</div>
                <div class="text-[0.6875rem] text-ink-400">{t.relation}</div>
              </div>
            </a>
          ))}
        </div>
      </div>

      {/* Recommended reading — driven by data */}
      <div class="aside-card">
        <p class="aside-card-title">Odporúčané čítanie</p>
        <ul class="space-y-1.5 text-ink-500">
          {recommendedReading.map((r) => (
            <li set:html={r.citation} />
          ))}
        </ul>
      </div>

    </aside>

  </div>

</BaseLayout>

{/* ================================================================
    MODULE SCRIPTS
    - Print button via addEventListener (CSP-safe, no inline onclick)
    - Broken-image fallback: sets [data-broken] attr so CSS can style it
    ================================================================ */}
<script>
  document.getElementById('print-btn')?.addEventListener('click', () => window.print());

  document.querySelectorAll('.essay-figure img').forEach(img => {
    img.addEventListener('error', () => img.setAttribute('data-broken', ''));
  });
</script>
